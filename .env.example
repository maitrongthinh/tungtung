# Copy file này thành .env rồi điền giá trị thật.
# KHÔNG commit file .env lên git.

# ── AI / LLM ──────────────────────────────────────────────────────────────────
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
# Hoặc dùng Anthropic:
# ANTHROPIC_API_KEY=
# AI_BASE_URL=https://api.anthropic.com/v1

# ── Shopee Affiliate ──────────────────────────────────────────────────────────
SHOPEE_AFFILIATE_TOKEN=
SHOPEE_AFFILIATE_CREDENTIAL=
SHOPEE_AFFILIATE_SECRET=
SHOPEE_PUBLISHER_ID=
SHOPEE_SUB_ID_PREFIX=shopee-agent
# Cookie JSON array từ browser (Export cookies extension):
SHOPEE_AFFILIATE_COOKIE=

# ── Meta / Facebook ───────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=

# ── Web server ────────────────────────────────────────────────────────────────
# Khóa bí mật cho session/JWT (tạo bằng: python -c "import secrets; print(secrets.token_hex(32))")
# SECRET_KEY=<required-for-dashboard-auth><generate-a-strong-random-key>-with-random-hex-32bytes
PUBLIC_BASE_URL=https://your-domain.example

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
PROXY_LIST=
